<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinhasCompras.Views.NovoProduto"
             Title="NovoProduto">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>
    
    
    <VerticalStackLayout Spacing="10" Padding="10">

        <Label Text="Descricao do Produto:"/>
        <Entry x:Name="txt_desc"/>

        <Label Text="Quantidade:"/>
        <Entry x:Name="txt_Quant" Keyboard="Numeric"/>

        <Label Text="Preco Unitário"/>
        <Entry x:Name="txt_preco" Keyboard="Numeric"/>

    </VerticalStackLayout>
</ContentPage>