<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1"/>
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked"/>
        <ToolbarItem Text="Relatório" Clicked="ToolbarItem_Clicked_2"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
    
    
    
    
    
    
    
    <StackLayout>
        <SearchBar x:Name="txt_search" Placeholder="Busca de produtos"
                   TextChanged="Txt_search_TextChanged"
                   Margin="0,0,0,0"
                   
                   />
        <Frame Padding="0" Margin="10" VerticalOptions="FillAndExpand">
            <ListView x:Name="lst_produto" ItemSelected="lst_produto_ItemSelected" IsPullToRefreshEnabled="True"
                 Refreshing="lst_produto_Refreshing">
                <ListView.Header>
                    <Grid ColumnDefinitions="*,*,*,*,*,*"
                          BackgroundColor="{StaticResource Gray100}">
                        <Label Grid.Column="0" Text="Id" Padding="5" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="descrição" FontAttributes="Bold"/>
                        <Label Grid.Column="2" Text="Categoria" FontAttributes="Bold"/>
                        <Label Grid.Column="3" Text="Preco" FontAttributes="Bold"/>
                        <Label Grid.Column="4" Text="Quant" FontAttributes="Bold"/>
                        <Label Grid.Column="5" Text="Total" FontAttributes="Bold" />
                    </Grid>

                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ViewCell.ContextActions>
                                <MenuItem Text="Remover" Clicked="MenuItem_Clicked"/>
                            </ViewCell.ContextActions>
                            <Grid ColumnDefinitions="*,*,*,*,*,*">
                                <Label Grid.Column="0" Text= "{Binding Id}" Padding="5"/>
                                <Label Grid.Column="1" Text="{Binding Descricao}"/>
                                <Label Grid.Column="2" Text="{Binding Categoria}"/>
                                <Label Grid.Column="3" Text="{Binding Preco,StringFormat='{}{0:C}'}"/>
                                <Label Grid.Column="4" Text="{Binding Quantidade}"/>
                                <Label Grid.Column="5" Text="{Binding Total, StringFormat='{}{0:C}'}"/>
                            </Grid>

                        </ViewCell>

                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Frame>

    </StackLayout>
</ContentPage>